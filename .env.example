# ── Strava OAuth2 ─────────────────────────────────────────────────────────────
# Get from https://www.strava.com/settings/api
# Note: Strava API requires a paid subscription since May 2025.
# The app works without Strava — Garmin, Weather and Routes remain fully functional.
CLIENT_ID=your_strava_client_id
CLIENT_SECRET=your_strava_client_secret

# ── LLM provider ──────────────────────────────────────────────────────────────
# Which provider the app uses:
#   openai (KIT / any OpenAI-compatible endpoint, default) | openai_official (api.openai.com) | gemini
LLM_PROVIDER=openai

# ── LLM: OpenAI-compatible (KIT Gateway) ──────────────────────────────────────
# KIT students: get your key from the Übungsleitung / DSI portal
# Available models: kit.gpt-4.1, kit.gpt-5, kit.gpt-5-mini, meta-llama-3.1-8b-instruct
OPENAI_API_KEY=your_kit_api_key
OPENAI_BASE_URL=https://ai-gateway.dsi-experimente.de/v1
AGENT_MODEL=kit.gpt-4.1
# Optional: a dedicated (stable) model for the multi-call agent layer; falls back to AGENT_MODEL
AGENT_LLM_MODEL=kit.gpt-4.1

# ── LLM: Official OpenAI (when LLM_PROVIDER=openai_official) ───────────────────
# Real OpenAI key from https://platform.openai.com/api-keys
OPENAI_OFFICIAL_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
# Optional: only for Azure/proxy; blank = https://api.openai.com/v1
OPENAI_OFFICIAL_BASE_URL=

# ── LLM: Google Gemini (when LLM_PROVIDER=gemini) ─────────────────────────────
# Free key at https://aistudio.google.com/apikey (needs free-tier quota enabled on the project)
GEMINI_API_KEY=your_gemini_api_key
# Free flash models: gemini-2.0-flash, gemini-2.5-flash, gemini-flash-latest
GEMINI_MODEL=gemini-2.0-flash

# ── Garmin Connect ────────────────────────────────────────────────────────────
# Optional — enables Health tab and Garmin activity data in Chat
# Option A: use real credentials (run auth/garmin_setup.py once to cache tokens)
GARMIN_EMAIL=your_garmin_email@example.com
GARMIN_PASSWORD=your_garmin_password
# Option B: use mock data (no real device/account needed — toggle in ⚙️ Settings)
GARMIN_MOCK_HEALTH=false

# ── OpenRouteService ──────────────────────────────────────────────────────────
# Optional — enables route planning (plan_route, explore_trails, isochrone)
# Free key at https://openrouteservice.org/dev/#/signup (2 000 req/day, no credit card)
ORS_API_KEY=your_ors_api_key

# ── Telegram (optional) ───────────────────────────────────────────────────────
# Bridges the external stdio server github.com/chigwell/telegram-mcp onto this app
# via servers/telegram_mcp.py (proxy). Upstream is vendored in ./external/telegram-mcp.
# API_ID / API_HASH from https://my.telegram.org/apps
TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash
# Generate ONCE (interactive — login is disabled when run as a server), then paste here:
#   uv run --directory external/telegram-mcp session_string_generator.py
TELEGRAM_SESSION_STRING=your_telegram_session_string
# Optional: expose only read tools — TELEGRAM_EXPOSED_TOOLS=read-only

# ── Telegram agent bridge (optional) ──────────────────────────────────────────
# Chat with the agent from Telegram: `python telegram_bridge.py` runs a userbot
# that forwards every incoming message to the agent and replies (with route maps).
# Reuses TELEGRAM_API_ID/HASH + TELEGRAM_SESSION_STRING above by default.
# TELEGRAM_ALLOWED_USERS=          # comma-separated user IDs / @usernames; empty = anyone
# TELEGRAM_BRIDGE_ALLOW_GROUPS=false   # true → also answer in group chats (default: DMs only)
# TELEGRAM_BRIDGE_HISTORY=10           # turns of context kept per chat
# Only needed to run the bridge AND the telegram-mcp proxy at the same time
# (avoids AuthKeyDuplicated). Make one with: python telegram_bridge.py --login
# TELEGRAM_BRIDGE_SESSION_STRING=
#
# Voice memos sent to the bridge are transcribed locally with Whisper (de/en, auto).
# WHISPER_MODEL=small    # tiny|base|small|medium|large-v3 — bigger = better German, slower
# WHISPER_BACKEND=       # mlx|faster|openai (default: auto — mlx on Apple Silicon w/ ffmpeg, else faster)
# WHISPER_LANGUAGE=      # force a language e.g. de/en (default: auto-detect)

# ── Google Calendar ───────────────────────────────────────────────────────────
# Optional — enables calendar integration in Chat
# Create credentials at https://console.cloud.google.com/apis/credentials
# After setting these, run: python auth/google_oauth.py
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── Access PIN (optional) ─────────────────────────────────────────────────────
# Set DO_LOCK=true to enable the PIN gate, then set APP_PIN to your desired PIN.
# Alternatively set APP_PIN in .streamlit/secrets.toml as APP_PIN = "1234"
DO_LOCK=false
# APP_PIN=1234

# ── MLflow tracing (optional) ─────────────────────────────────────────────────
# The agent layer (orchestrator + specialists) and the chart service trace every
# LLM / tool call to an MLflow server. ./dev_stack.sh and ./start.sh start that
# server on :5001 for you — open http://localhost:5001 to browse the traces.
MLFLOW_TRACKING_URI=http://127.0.0.1:5001
MLFLOW_EXPERIMENT=fitdash
# Set to 0/false/off to turn tracing off entirely (the app still runs).
MLFLOW_TRACING=1

# ── Google Geocoding (optional) ───────────────────────────────────────────────
# Enables the routes "geocode" tool (place name → coordinates), so the route agent
# can anchor loops/routes at named places (e.g. "Schlossgarten") instead of the
# home coordinate. Enable the Geocoding API and create a key at
# https://developers.google.com/maps/documentation/geocoding/get-api-key
GOOGLE_GEOCODING_API_KEY=your_google_geocoding_api_key_here

# ── Google Maps MCP (optional) ────────────────────────────────────────────────
# Enables the google_maps MCP server (servers/google_maps_mcp.py), a proxy that
# bridges the upstream @modelcontextprotocol/server-google-maps onto the bus —
# geocoding, place search, place details, directions, distance matrix and
# elevation in Chat. Needs Node.js/npm on PATH (the proxy launches the upstream
# with `npx`). Enable the Places API (+ Geocoding/Directions) and create a key at
# https://console.cloud.google.com/google/maps-apis/credentials
# Also used as a fallback key for the routes "geocode" tool above.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Fitness Expert agent — local RAG (optional) ───────────────────────────────
# The fitness specialist (:9005) retrieves from a local vector DB of public-domain
# fitness books using a small LOCAL embedding model — no API key needed. Defaults
# are fine; override only to change the model, device, or index location.
# FITNESS_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# FITNESS_EMBED_DEVICE=mps        # auto-detected (mps → cuda → cpu); set to force
# FITNESS_INDEX_DIR=data/fitness_library/index
