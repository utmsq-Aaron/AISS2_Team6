# Strava OAuth2 Configuration
CLIENT_ID=your_strava_client_id_here
CLIENT_SECRET=your_strava_client_secret_here

#Garmin Connect Configuration
GARMIN_EMAIL=your_garmin_email_here
GARMIN_PASSWORD=your_garmin_password_here

#ki-toolbox
#OPENAI_API_KEY=your_ki_toolbox_api_key_here
#OPENAI_BASE_URL=https://ki-toolbox.scc.kit.edu/api/v1
#AGENT_MODEL=azure.gpt-5-mini

#ai-gateway
OPENAI_BASE_URL=https://ai-gateway.dsi-experimente.de
OPENAI_API_KEY=your_ai_gateway_api_key_here
AGENT_MODEL=kit.gpt-5-mini

# Open Route Service
ORS_API_KEY=your_openrouteservice_api_key_here

# Mock Garmin health data (no real account needed) — set true for local dev/testing
GARMIN_MOCK_HEALTH=False

# Google Calendar Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Lock app behind PIN
DO_LOCK=False
APP_PIN=1234