# ── Strava OAuth2 ─────────────────────────────────────────────────────────────
# Get from https://www.strava.com/settings/api
# Note: Strava API requires a paid subscription since May 2025.
# The app works without Strava — Garmin, Weather and Routes remain fully functional.
CLIENT_ID=your_strava_client_id
CLIENT_SECRET=your_strava_client_secret

# ── LLM (KIT Gateway) ─────────────────────────────────────────────────────────
# KIT students: get your key from the Übungsleitung / DSI portal
# Available models: kit.gpt-4.1, kit.gpt-5, kit.gpt-5-mini, meta-llama-3.1-8b-instruct
OPENAI_API_KEY=your_kit_api_key
OPENAI_BASE_URL=https://ai-gateway.dsi-experimente.de/v1
AGENT_MODEL=kit.gpt-4.1

# ── Garmin Connect ────────────────────────────────────────────────────────────
# Optional — enables Health tab and Garmin activity data in Chat
# Option A: use real credentials (run auth/garmin_setup.py once to cache tokens)
GARMIN_EMAIL=your_garmin_email@example.com
GARMIN_PASSWORD=your_garmin_password
# Option B: use mock data (no real device/account needed — toggle in ⚙️ Settings)
GARMIN_MOCK_HEALTH=false

# ── OpenRouteService ──────────────────────────────────────────────────────────
# Optional — enables route planning (plan_route, explore_trails, isochrone)
# Free key at https://openrouteservice.org/dev/#/signup (2 000 req/day, no credit card)
ORS_API_KEY=your_ors_api_key

# ── Telegram (optional) ───────────────────────────────────────────────────────
# Bridges the external stdio server github.com/chigwell/telegram-mcp onto this app
# via servers/telegram_mcp.py (proxy). Upstream is vendored in ./external/telegram-mcp.
# API_ID / API_HASH from https://my.telegram.org/apps
TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash
# Generate ONCE (interactive — login is disabled when run as a server), then paste here:
#   uv run --directory external/telegram-mcp session_string_generator.py
TELEGRAM_SESSION_STRING=your_telegram_session_string
# Optional: expose only read tools — TELEGRAM_EXPOSED_TOOLS=read-only

# ── Telegram agent bridge (optional) ──────────────────────────────────────────
# Chat with the agent from Telegram: `python telegram_bridge.py` runs a userbot
# that forwards every incoming message to the agent and replies (with route maps).
# Reuses TELEGRAM_API_ID/HASH + TELEGRAM_SESSION_STRING above by default.
# TELEGRAM_ALLOWED_USERS=          # comma-separated user IDs / @usernames; empty = anyone
# TELEGRAM_BRIDGE_ALLOW_GROUPS=false   # true → also answer in group chats (default: DMs only)
# TELEGRAM_BRIDGE_HISTORY=10           # turns of context kept per chat
# Only needed to run the bridge AND the telegram-mcp proxy at the same time
# (avoids AuthKeyDuplicated). Make one with: python telegram_bridge.py --login
# TELEGRAM_BRIDGE_SESSION_STRING=
#
# Voice memos sent to the bridge are transcribed locally with Whisper (de/en, auto).
# WHISPER_MODEL=small    # tiny|base|small|medium|large-v3 — bigger = better German, slower
# WHISPER_BACKEND=       # mlx|faster|openai (default: auto — mlx on Apple Silicon w/ ffmpeg, else faster)
# WHISPER_LANGUAGE=      # force a language e.g. de/en (default: auto-detect)

# ── Google Calendar ───────────────────────────────────────────────────────────
# Optional — enables calendar integration in Chat
# Create credentials at https://console.cloud.google.com/apis/credentials
# After setting these, run: python auth/google_oauth.py
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── Access PIN (optional) ─────────────────────────────────────────────────────
# Set DO_LOCK=true to enable the PIN gate, then set APP_PIN to your desired PIN.
# Alternatively set APP_PIN in .streamlit/secrets.toml as APP_PIN = "1234"
DO_LOCK=false
# APP_PIN=1234
