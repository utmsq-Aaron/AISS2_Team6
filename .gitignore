# Environment and credentials - NEVER commit these!
.env
.env.local
.env.production

# Python virtual environments
.venv
venv/
env/

# Python compiled files
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb

# Database files
*.db
*.sqlite3

# MLflow tracing store (mlflow.db is covered by *.db above; these are artifact dirs)
mlruns/
mlartifacts/

# Runtime API cache (regenerated on demand)
.cache/

# Log files
*.log
logs/
.logs/

# Temporary debug output only — real test scripts and logs are committed
tests/logs/tmp_*.txt

# OAuth2 tokens - NEVER commit these!
.tokens/

# Streamlit secrets (config.toml is safe to commit, secrets.toml is not)
.streamlit/secrets.toml

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Private file
importable_smartwatch_data/*
# Local Claude config
.claude/

# Node.js dependencies & build output (React frontend in web/, Node BFF in server/)
node_modules/
web/dist/
server/dist/
.vite/
*.tsbuildinfo

# Playwright MCP scratch output
.playwright-mcp/

# Fitness RAG built vector index — derived artifact, rebuilt from the committed
# corpus via `python -m scripts.build_fitness_index` (the launch scripts do this).
data/fitness_library/index/

# Per-user conversation vector stores + turn bookkeeping — runtime memory that
# grows as users chat. The seed soul.md profiles ARE tracked (the agent rewrites
# them over time, so those edits show up as diffs); the embedded conversation
# vectors and the turn counter are per-deployment runtime state, not committed.
data/user_memory/*/conversations/
data/user_memory/*/meta.json