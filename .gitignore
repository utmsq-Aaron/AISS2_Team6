# Environment and credentials - NEVER commit these!
.env
.env.local
.env.production

# Python virtual environments
.venv
venv/
env/

# Python compiled files
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb

# Database files
*.db
*.sqlite3

# Log files
*.log
logs/
.logs/

# Temporary debug output only — real test scripts and logs are committed
tests/logs/tmp_*.txt

# OAuth2 tokens - NEVER commit these!
.tokens/

# Streamlit secrets (config.toml is safe to commit, secrets.toml is not)
.streamlit/secrets.toml

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Private file
importable_smartwatch_data/*
# Local Claude config
.claude/
