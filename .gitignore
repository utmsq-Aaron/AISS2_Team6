# Environment and credentials - NEVER commit these!
.env
.env.local
.env.production

# Python virtual environments
.venv
venv/
env/

# Python compiled files
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb

# Database files
*.db
*.sqlite3

# MLflow tracing store (mlflow.db is covered by *.db above; these are artifact dirs)
mlruns/
mlartifacts/

# End-to-end evaluation outputs — per-run HTML reports + facts dumps (regenerated).
evaluation/reports/*
!evaluation/reports/.gitkeep

# Runtime API cache (regenerated on demand)
.cache/

# Log files
*.log
logs/
.logs/

# Temporary debug output only — real test scripts and logs are committed
tests/logs/tmp_*.txt

# OAuth2 tokens - NEVER commit these!
.tokens/

# Streamlit secrets (config.toml is safe to commit, secrets.toml is not)
.streamlit/secrets.toml

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Private file
importable_smartwatch_data/*
# Local Claude config
.claude/

# Node.js dependencies & build output (React frontend in web/, Node BFF in server/)
node_modules/
web/dist/
server/dist/
.vite/
*.tsbuildinfo

# Playwright MCP scratch output
.playwright-mcp/

# Fitness RAG built vector index — derived artifact, rebuilt from the committed
# corpus via `python -m scripts.build_fitness_index` (the launch scripts do this).
data/fitness_library/index/

# Per-user memory — entirely per-deployment runtime state, never committed:
# the soul.md profiles (rewritten by the agent over time), the embedded
# conversation vectors, and the turn counter. Created on demand at runtime.
data/user_memory/

# Registered accounts (email → created/last_login) — per-deployment runtime state.
data/accounts.json

# Persisted chat sessions (per-user conversation history) — runtime state.
data/chats/

# Persisted launcher secrets (the stable AUTH_SECRET) — never commit.
.secrets/